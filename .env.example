# SolveX Backend — Environment Variables
# Copy to .env for local development.
# In production (Railway), set these directly in the Railway dashboard.
# Never commit a filled-in .env file to git.
#
# ─── App environment ──────────────────────────────────────────────────────────
APP_ENV=production
ENABLE_DEBUG_ENDPOINT=false

# ─── Server port ──────────────────────────────────────────────────────────────
# Railway sets $PORT automatically — do NOT hardcode this in production.
# For local dev: set PORT=8000 in your .env file.
# PORT=8000

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Add your Vercel deployment URL here.
# Example: https://solvex.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=https://your-solvex.vercel.app,http://localhost:3000,http://localhost:3001,http://localhost:5173

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_ANALYZE_SECONDS=30

# ─── Logging / observability ─────────────────────────────────────────────────
# One of DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# ─── Feature flags ────────────────────────────────────────────────────────────
# Comma-separated flag names, e.g. FEATURE_FLAGS=skilltrace,beta_queue
FEATURE_FLAGS=

# ─── Backend jobs persistence ─────────────────────────────────────────────────
# SQLite path for the shared store: backend_jobs, users/entitlements, the
# Codeforces problem catalog, and problem_skill_map all live in this ONE file.
# A relative path (the default) resolves against the container's working
# directory, which is WIPED on every Railway redeploy — that includes the
# problem catalog and skill map, which will empty the daily queue/plans until
# they're reseeded. See "Persistent Storage on Railway" in docs/deployment.md.
# Production Postgres schema: db/migrations/007_backend_jobs.sql and 008_cf_data_platform.sql
DATABASE_PATH=api_cache/backend_jobs.db
# On Railway, after attaching a volume mounted at /data:
# DATABASE_PATH=/data/backend_jobs.db

# ─── Startup catalog auto-seed (opt-in, off by default) ──────────────────────
# If set via FEATURE_FLAGS below, the backend checks at startup whether the
# problem catalog/skill map are empty and, only if so, seeds them in the
# background (never blocks startup, never re-runs while data already exists).
# This hits the live Codeforces API, so it stays off unless explicitly enabled:
# FEATURE_FLAGS=auto_seed_catalog_on_startup

# ─── Codeforces client pacing ─────────────────────────────────────────────────
CODEFORCES_RATE_LIMIT_SECONDS=2.0
CODEFORCES_MAX_RETRIES=3
# Global problemset snapshot refresh interval (fetched once for all users).
CODEFORCES_PROBLEMSET_TTL_HOURS=24

# ─── Billing (Phase 06) ───────────────────────────────────────────────────────
# Provider for checkout: manual (paid beta), local (dev), stripe (needs BILLING_API_KEY).
BILLING_PROVIDER=manual
BILLING_API_KEY=
BILLING_WEBHOOK_SECRET=

# ─── Admin bootstrap key ──────────────────────────────────────────────────────
# Grants admin access via the X-Admin-Key header (create users, grant plans,
# retry jobs). Set a long random value; leave empty to disable key-based admin.
ADMIN_API_KEY=

# ─── AI Copilot (DeepSeek) ───────────────────────────────────────────────────
# Required for /api/copilot to work.
# NEVER put these in Vercel environment variables — backend-only secrets.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ─── Coach Memory AI summary (optional, costs tokens) ────────────────────────
# When true, uses DeepSeek to generate profile summaries.
# Deterministic summaries are used when false (default).
ENABLE_AI_PROFILE_SUMMARY=false

# ─── Supabase ─────────────────────────────────────────────────────────────────
# SUPABASE_URL and the three JWT values are required in production. The JWT
# issuer is normally <SUPABASE_URL>/auth/v1 and its JWKS endpoint is
# <issuer>/.well-known/jwks.json. Use the audience configured for signed-in
# users (normally "authenticated"). The project must use an asymmetric JWT
# signing key (RS256/ES256); the JWKS endpoint cannot verify legacy HS256 keys.
SUPABASE_URL=https://your-project.supabase.co
# Example: https://your-project.supabase.co/auth/v1
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_AUDIENCE=authenticated
# Example: https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=

# Optional backend-only data export/Coach persistence credential. It is not
# used to authenticate users. Never put it in Vercel or any NEXT_PUBLIC_ var.
SUPABASE_SERVICE_KEY=

# ─── Judge0 (code execution) ──────────────────────────────────────────────────
# Leave empty to disable the compiler (execute API returns HTTP 503).
# Option A: self-hosted on a VPS
#   JUDGE0_BASE_URL=https://judge0.your-domain.com
# Option B: RapidAPI hosted Judge0 CE
#   JUDGE0_BASE_URL=https://judge0-ce.p.rapidapi.com
#   JUDGE0_API_KEY=your_rapidapi_key
#   JUDGE0_API_HOST=judge0-ce.p.rapidapi.com
# Option C: local Docker (dev only)
#   JUDGE0_BASE_URL=http://localhost:2358
JUDGE0_BASE_URL=
JUDGE0_API_KEY=
JUDGE0_API_HOST=
# Public base URL of THIS backend, used for Judge0 PUT callbacks
# (e.g. https://api.solvex.app). Leave empty to rely on the polling reconciler.
JUDGE0_CALLBACK_BASE=
